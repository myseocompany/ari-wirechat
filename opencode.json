{
    "$schema": "https://opencode.ai/config.json",
    "mcp": {
        "laravel-boost": {
            "type": "local",
            "enabled": true,
            "command": [
                "php",
                "artisan",
                "boost:mcp"
            ]
        },
        "apify-instagram": {
            "type": "remote",
            "enabled": true,
            "url": "https://mcp.apify.com?tools=apify/instagram-scraper",
            "oauth": false,
            "headers": {
                "Authorization": "Bearer {env:APIFY_TOKEN}"
            }
        }
    }
}
